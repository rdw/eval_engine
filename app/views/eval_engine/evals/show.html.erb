<% unless @selected_run %>
  <%= turbo_stream_from @eval_name, "examples" %>
  <%= turbo_stream_from @eval_name, "runs" %>
<% end %>

<nav class="ee-breadcrumb">
  <%= link_to "Evals", root_path %> / <%= @eval_name %>
</nav>

<div class="ee-page-header">
  <h1><%= @eval_name %></h1>
  <div class="ee-actions">
    <%= button_to "Run all", eval_runs_path(@eval_name), method: :post, class: "ee-btn ee-btn--primary" %>
    <%= button_to "Rescore", eval_rescore_path(@eval_name), method: :post, class: "ee-btn" %>
  </div>
</div>

<section class="ee-summary">
  <div class="ee-summary__cell">
    <span class="ee-summary__label">Latest</span>
    <span class="ee-summary__value"><%= score_cell(@latest) %></span>
    <span class="ee-summary__detail"><%= coverage_text(@latest) %></span>
  </div>
  <div class="ee-summary__cell">
    <span class="ee-summary__label">Checkpoint</span>
    <span class="ee-summary__value"><%= score_cell(@checkpoint) %></span>
    <span class="ee-summary__detail"><%= checkpoint_detail(@checkpoint) %></span>
  </div>
</section>

<section class="ee-section">
  <h2>
    Examples (<%= @example_rows.length %>)
    <% if @selected_run %>
      — showing run started <%= @selected_run.started_at&.iso8601 %>
      (<%= link_to "show latest", eval_path(@eval_name) %>)
    <% end %>
  </h2>
  <% if @example_rows.empty? %>
    <p class="ee-empty">No examples yet.</p>
  <% else %>
    <% sort_args = { eval_name: @eval_name, current_sort: @sort_column, current_dir: @sort_direction } %>
    <% example_link_params = @selected_run ? { run_id: @selected_run.id } : {} %>
    <table class="ee-table">
      <thead>
        <tr>
          <th><%= sort_link("key", "Key", **sort_args) %></th>
          <th><%= sort_link("status", "Status", **sort_args) %></th>
          <th class="ee-table__num"><%= sort_link("score", "Score", **sort_args) %></th>
          <th class="ee-table__num"><%= sort_link("duration", "Duration", **sort_args) %></th>
          <th><%= sort_link("last_run_at", "Last run", **sort_args) %></th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <%= render partial: "example_row", collection: @example_rows, as: :row, locals: { eval_name: @eval_name, example_link_params: example_link_params } %>
      </tbody>
    </table>
  <% end %>
</section>

<section class="ee-section">
  <h2>Recent runs (<%= @runs.length %>)</h2>
  <% if @runs.empty? %>
    <p class="ee-empty">No runs yet.</p>
  <% else %>
    <table class="ee-table">
      <thead>
        <tr>
          <th>Started</th>
          <th>Status</th>
          <th class="ee-table__num">Examples</th>
          <th class="ee-table__num">Mean score</th>
          <th class="ee-table__num">Errored</th>
          <th class="ee-table__num">Duration</th>
          <th></th>
        </tr>
      </thead>
      <tbody id="eval_engine_runs_table">
        <%= render partial: "run_row", collection: @runs, as: :run, locals: { eval_name: @eval_name, selected_run_id: @selected_run&.id } %>
      </tbody>
    </table>
  <% end %>
</section>

<nav class="ee-breadcrumb">
  <%= link_to "Evals", root_path %> / <%= @eval_name %>
</nav>

<div class="ee-page-header">
  <h1><%= @eval_name %></h1>
  <div class="ee-actions">
    <%= button_to "Run all", eval_runs_path(@eval_name), method: :post, class: "ee-btn ee-btn--primary" %>
    <%= button_to "Promote latest", eval_checkpoint_path(@eval_name), method: :post, class: "ee-btn" %>
    <%= button_to "Rescore", eval_rescore_path(@eval_name), method: :post, class: "ee-btn" %>
  </div>
</div>

<section class="ee-summary">
  <div class="ee-summary__cell">
    <span class="ee-summary__label">Latest</span>
    <span class="ee-summary__value"><%= score_cell(@latest) %></span>
    <span class="ee-summary__detail"><%= coverage_text(@latest) %></span>
  </div>
  <div class="ee-summary__cell">
    <span class="ee-summary__label">Checkpoint</span>
    <span class="ee-summary__value"><%= score_cell(@checkpoint) %></span>
    <span class="ee-summary__detail"><%= checkpoint_detail(@checkpoint) %></span>
  </div>
</section>

<section class="ee-section">
  <h2>
    Examples (<%= @example_rows.length %>)
    <% if @selected_run %>
      — showing run started <%= @selected_run.started_at&.iso8601 %>
      (<%= link_to "show latest", eval_path(@eval_name) %>)
    <% end %>
  </h2>
  <% if @example_rows.empty? %>
    <p class="ee-empty">No examples yet.</p>
  <% else %>
    <% sort_args = { eval_name: @eval_name, current_sort: @sort_column, current_dir: @sort_direction } %>
    <% example_link_params = @selected_run ? { run_id: @selected_run.id } : {} %>
    <table class="ee-table">
      <thead>
        <tr>
          <th><%= sort_link("key", "Key", **sort_args) %></th>
          <th><%= sort_link("status", "Status", **sort_args) %></th>
          <th class="ee-table__num"><%= sort_link("score", "Score", **sort_args) %></th>
          <th class="ee-table__num"><%= sort_link("duration", "Duration", **sort_args) %></th>
          <th><%= sort_link("last_run_at", "Last run", **sort_args) %></th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @example_rows.each do |row| %>
          <tr class="<%= "ee-row--muted" unless row[:in_run] %>">
            <td><%= link_to row[:key], eval_example_path(@eval_name, row[:key], **example_link_params) %></td>
            <td>
              <% if row[:in_run] %>
                <%= example_status_pill(row[:latest]) %>
              <% else %>
                <span class="ee-pill ee-pill--missing">not in this run</span>
              <% end %>
            </td>
            <td class="ee-table__num"><%= example_score_cell(row[:latest]) %></td>
            <td class="ee-table__num"><%= example_duration(row[:latest]) %></td>
            <td><%= row[:last_run_at]&.iso8601 || "—" %></td>
            <td class="ee-table__num">
              <%= button_to "Run", eval_runs_path(@eval_name, only: row[:key]), method: :post, class: "ee-btn ee-btn--small" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</section>

<section class="ee-section">
  <h2>Recent runs (<%= @runs.length %>)</h2>
  <% if @runs.empty? %>
    <p class="ee-empty">No runs yet.</p>
  <% else %>
    <table class="ee-table">
      <thead>
        <tr>
          <th>Started</th>
          <th>Status</th>
          <th class="ee-table__num">Examples</th>
          <th class="ee-table__num">Mean score</th>
          <th class="ee-table__num">Errored</th>
          <th class="ee-table__num">Duration</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @runs.each do |run| %>
          <% is_current = @selected_run && run.id == @selected_run.id %>
          <tr class="<%= "ee-row--current" if is_current %>">
            <td>
              <% started = run.started_at&.iso8601 %>
              <% if is_current %>
                <span class="ee-link--current"><%= started %></span>
              <% else %>
                <%= link_to started, eval_path(@eval_name, run_id: run.id) %>
              <% end %>
            </td>
            <td><%= status_pill(run.status) %></td>
            <td class="ee-table__num"><%= run.example_count %></td>
            <td class="ee-table__num"><%= format_score(run.run_examples.average(:score)) %></td>
            <td class="ee-table__num"><%= run.run_examples.errored.count %></td>
            <td class="ee-table__num"><%= duration_text(run) %></td>
            <td class="ee-table__num">
              <%= button_to "Promote", eval_checkpoint_path(@eval_name, run_id: run.id), method: :post, class: "ee-btn ee-btn--small" %>
              <%= button_to "Delete", eval_run_path(@eval_name, run.id), method: :delete, class: "ee-btn ee-btn--small ee-btn--danger" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</section>

<h1>Evals</h1>

<% if @evals.empty? %>
  <p class="ee-empty">
    No evals found under <code><%= EvalEngine.configuration.eval_root %></code>.
  </p>
<% else %>
  <table class="ee-table">
    <thead>
      <tr>
        <th>Name</th>
        <th class="ee-table__num">Examples</th>
        <th class="ee-table__num">Latest</th>
        <th class="ee-table__num">Checkpoint</th>
      </tr>
    </thead>
    <tbody>
      <% @evals.each do |row| %>
        <tr>
          <td><%= link_to row[:name], eval_path(row[:name]) %></td>
          <td class="ee-table__num"><%= example_total(row[:latest]) %></td>
          <td class="ee-table__num"><%= score_cell(row[:latest]) %></td>
          <td class="ee-table__num"><%= score_cell(row[:checkpoint]) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>

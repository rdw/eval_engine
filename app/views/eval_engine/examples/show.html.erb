<nav class="ee-breadcrumb">
  <%= link_to "Evals", root_path %>
  /
  <%= link_to @eval_name, eval_path(@eval_name) %>
  /
  <%= @example_key %>
</nav>

<div class="ee-page-header">
  <h1><%= @example_key %></h1>
  <div class="ee-actions">
    <%= button_to "Run this example", eval_runs_path(@eval_name, only: @example_key), method: :post, class: "ee-btn ee-btn--primary" %>
  </div>
</div>

<% if @selected.nil? %>
  <section class="ee-section">
    <p class="ee-empty">No runs yet for this example.</p>
  </section>
<% elsif @selected.errored? %>
  <section class="ee-section">
    <h2>Run errored (<%= @selected.started_at&.iso8601 %>)</h2>
    <pre class="ee-codeblock ee-codeblock--error"><%= @selected.error %></pre>
  </section>
<% else %>
  <section class="ee-section">
    <h2>Diff (score: <%= example_score_cell(@selected) %>, ran <%= @selected.started_at&.iso8601 %>)</h2>
    <%= render_diff_for(output_type: @output_type, eval_name: @eval_name, score_tree: @selected.score_tree, expected: @example.expected, output: @selected.output) %>
  </section>
<% end %>

<section class="ee-section">
  <details class="ee-disclosure">
    <summary class="ee-disclosure__summary">Input</summary>
    <%= format_json_block(@example.input) %>
  </details>
</section>

<section class="ee-section">
  <details class="ee-disclosure">
    <summary class="ee-disclosure__summary">Expected</summary>
    <%= format_json_block(@example.expected) %>
  </details>
</section>

<% if @selected && !@selected.errored? %>
  <section class="ee-section">
    <details class="ee-disclosure">
      <summary class="ee-disclosure__summary">Output</summary>
      <%= format_json_block(@selected.output) %>
    </details>
  </section>
<% end %>

<section class="ee-section">
  <h2>History (<%= @history.length %>)</h2>
  <% if @history.empty? %>
    <p class="ee-empty">No runs yet.</p>
  <% else %>
    <table class="ee-table">
      <thead>
        <tr>
          <th>Started</th>
          <th>Status</th>
          <th class="ee-table__num">Score</th>
          <th class="ee-table__num">Duration</th>
        </tr>
      </thead>
      <tbody>
        <% @history.each do |re| %>
          <% is_current = @selected && re.id == @selected.id %>
          <tr class="<%= "ee-row--current" if is_current %>">
            <td>
              <% started = re.started_at&.iso8601 %>
              <% if is_current %>
                <span class="ee-link--current"><%= started %></span>
              <% else %>
                <%= link_to started, eval_example_path(@eval_name, @example_key, run_id: re.run_id) %>
              <% end %>
            </td>
            <td><%= status_pill(re.status) %></td>
            <td class="ee-table__num"><%= example_score_cell(re) %></td>
            <td class="ee-table__num"><%= example_duration(re) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</section>
